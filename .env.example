VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Local: http://localhost:3001
# Produccion: https://URL_REAL_DEL_BACKEND o vacio solo si /api esta proxyado en el mismo dominio.
VITE_BACKEND_URL=http://localhost:3001
VITE_STRIPE_PUBLISHABLE_KEY=

# Cloudflare Turnstile site key (publica, se incrusta en el cliente).
# La secret key NO va aqui ni en el frontend: se configura en Supabase Dashboard
# > Authentication > Settings > CAPTCHA protection (provider: Turnstile).
VITE_TURNSTILE_SITE_KEY=
